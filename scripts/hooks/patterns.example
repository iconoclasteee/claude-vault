# Patterns that block commits in this repo.
# Copy this file to patterns.local (which is gitignored) and replace the
# example values below with your actual sensitive strings. One extended
# regex per line. Lines starting with # or blank lines are ignored.

# --- Personal identifiers (REPLACE WITH YOUR VALUES) ---
# /Users/<your-macos-username>
# /home/<your-linux-username>
# <your-ssh-alias>
# <your\.email>@<domain>\.<tld>

# --- Token prefixes — safe to keep as-is on any machine ---
ghp_[A-Za-z0-9]
ghs_[A-Za-z0-9]
gho_[A-Za-z0-9]
sk-ant-[A-Za-z0-9]
xoxb-[A-Za-z0-9]
xoxp-[A-Za-z0-9]
AKIA[A-Z0-9]{16}
BEGIN (RSA|OPENSSH|PGP) PRIVATE

# --- IPv4 catch-all — blocks any IPv4 in committed diffs ---
# The hook excludes third-party folders (skills/collections, .obsidian) so
# these vendor examples don't trip it. If you write an IP example in your
# own docs, use <ip> as placeholder or bypass with --no-verify after review.
\b(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9])(\.(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9])){3}\b
