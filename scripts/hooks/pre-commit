#!/usr/bin/env bash
# Pre-commit hook — bloque les commits contenant des identifiants personnels.
# Activation (une fois par clone) : git config core.hooksPath scripts/hooks

set -euo pipefail

# Patterns interdits. Ajoute une ligne par pattern à surveiller.
PATTERNS=(
  '<user-mac-path>'
  '<user-linux-path>'
  '<vps-host>'
  '<email>'
  'ghp_[A-Za-z0-9]'
  'sk-ant-[A-Za-z0-9]'
  'xoxb-[A-Za-z0-9]'
  'AKIA[A-Z0-9]{16}'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

FOUND=0
while IFS= read -r file; do
  [ -f "$file" ] || continue
  # Exclut le dossier du hook et SECURITY.md qui listent les patterns par définition.
  case "$file" in
    scripts/hooks/*) continue ;;
    SECURITY.md) continue ;;
  esac
  for pattern in "${PATTERNS[@]}"; do
    if git diff --cached -U0 -- "$file" | grep -E "^\+" | grep -E "$pattern" >/dev/null 2>&1; then
      echo "❌ Pattern interdit détecté dans $file : $pattern"
      FOUND=1
    fi
  done
done <<< "$STAGED"

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "Commit bloqué. Pour forcer (déconseillé) : git commit --no-verify"
  exit 1
fi

exit 0
